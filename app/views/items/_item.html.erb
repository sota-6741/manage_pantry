<div id="<%= dom_id(item) %>" class="item-card">
  <%# Item Name %>
  <div class="item-name">
    <%= link_to item.name, item_path(item) %>
  </div>

  <div class="item-details">
    <%# Category %>
    <div class="item-meta-row">
      <%= image_tag "icons/tag.svg", class: "item-meta-icon", alt: "Category" %>
      <span><%= item.category&.name || "-" %></span>
    </div>

    <%# Stock Adjustment Frame %>
    <%= turbo_frame_tag dom_id(item, :adjustment) do %>
      <%= render "stock_adjustments/display", item: item %>
    <% end %>

    <%# Expiration Date %>
    <div class="item-meta-row">
      <%= image_tag "icons/calendar.svg", class: "item-meta-icon", alt: "Date" %>
      <span><%= format_date(item.expiration_date) %></span>
    </div>
  </div>
</div>
